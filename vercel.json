{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": { "maxDuration": 30 }
  },
  "redirects": [
    {
      "source": "/api/categories",
      "destination": "/api/v1/categories",
      "permanent": false
    },
    {
      "source": "/api/articles/:slug",
      "destination": "/api/v1/articles/:slug",
      "permanent": false
    },
    {
      "source": "/api/articles",
      "destination": "/api/v1/articles",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/article/(.*)",
      "destination": "/deep_link_fallback.html"
    },
    {
      "source": "/app",
      "destination": "/app_universal_link.html"
    },
    {
      "source": "/app/",
      "destination": "/app_universal_link.html"
    },
    {
      "source": "/((?!\\.well-known/)(?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
