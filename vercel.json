{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/app",
      "destination": "/article/download",
      "permanent": false
    },
    {
      "source": "/app/",
      "destination": "/article/download",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/article/(.*)",
      "destination": "/deep_link_fallback.html"
    },
    {
      "source": "/((?!\\.well-known/).*)",
      "destination": "/index.html"
    }
  ]
}
